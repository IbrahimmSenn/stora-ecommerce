{
  "title": "Security",
  "uid": "shop-security",
  "tags": ["shop", "security"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Failed logins (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(shop_auth_login_total{result=\"failure\"}[1h])) or vector(0)",
          "legendFormat": "failures"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Login success ratio (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(shop_auth_login_total{result=\"success\"}[1h])) / sum(increase(shop_auth_login_total{result=~\"success|failure\"}[1h]))",
          "legendFormat": "success ratio"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Rate-limit rejections (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(shop_rate_limit_rejections_total[1h])) or vector(0)",
          "legendFormat": "429s"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Password resets requested (24h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(shop_auth_password_reset_total{event=\"requested\"}[24h])) or vector(0)",
          "legendFormat": "requested"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Failed login attempts by reason",
      "description": "invalid_credentials at volume = brute force / credential stuffing. invalid_2fa = someone past the password wall. 2FA challenges are tracked separately and are not failures.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0, "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (reason) (increase(shop_auth_login_total{result=\"failure\"}[5m]))",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Token refreshes by outcome",
      "description": "Failures include replayed (already-used) refresh tokens — the rotation-theft signal. A failure spike without a matching success spike is worth investigating.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (increase(shop_auth_refresh_total[5m]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Password reset events",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0, "custom": { "drawStyle": "bars", "fillOpacity": 60 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (event) (increase(shop_auth_password_reset_total[15m]))",
          "legendFormat": "{{event}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Rate-limit rejections by limiter",
      "description": "auth = the strict bucket on login/register/reset. general = the API-wide safety net.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (limiter) (increase(shop_rate_limit_rejections_total[5m]))",
          "legendFormat": "{{limiter}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Correlated: login failures vs auth-limiter 429s",
      "description": "Both rising together = an attack being throttled (the defense works). Failures rising while 429s stay flat = the attacker is under the limiter threshold — tighten AUTH_RATE_LIMIT_*. Neither series alone can tell these apart.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 22 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(shop_auth_login_total{result=\"failure\"}[5m]))",
          "legendFormat": "login failures (5m)"
        },
        {
          "refId": "B",
          "expr": "sum(increase(shop_rate_limit_rejections_total{limiter=\"auth\"}[5m]))",
          "legendFormat": "auth 429s (5m)"
        }
      ]
    },
    {
      "id": 10,
      "type": "logs",
      "title": "Security events (Loki)",
      "description": "Structured security log lines: failed logins, throttled clients, reset requests, refresh-token reuse, rejected webhooks.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 31 },
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=\"api\"} | json | msg=~\"login_failed|rate_limited|password_reset_requested|refresh_token_reuse|webhook_rejected\""
        }
      ]
    }
  ]
}
