{
  "title": "SLO / Error Budget",
  "uid": "shop-slo",
  "tags": ["shop", "slo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Availability SLI (1h)",
      "description": "Share of requests answered without a 5xx over the last hour. Target: 99.5%.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.995 },
              { "color": "green", "value": 0.999 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "sli:http_availability:ratio_rate1h", "legendFormat": "availability" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Latency SLI (1h)",
      "description": "Share of requests answered under 500ms over the last hour. Target: 95%.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "sli:http_latency_fast:ratio_rate1h", "legendFormat": "under 500ms" }
      ]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Availability budget left (30d)",
      "description": "How much of the monthly 0.5% error budget remains. Reads low until the recording rules have accumulated history — they only exist from the day this dashboard shipped.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "min": -1,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.25 },
              { "color": "green", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "clamp_min(1 - (1 - avg_over_time(sli:http_availability:ratio_rate1h[30d])) / 0.005, -1)",
          "legendFormat": "budget left"
        }
      ]
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Latency budget left (30d)",
      "description": "How much of the monthly 5% slow-request budget remains.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "min": -1,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.25 },
              { "color": "green", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "clamp_min(1 - (1 - avg_over_time(sli:http_latency_fast:ratio_rate1h[30d])) / 0.05, -1)",
          "legendFormat": "budget left"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Availability SLI trend",
      "description": "Non-5xx share at short (5m) and smoothed (1h) windows. The dashed threshold is the 99.5% SLO target.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "custom": { "thresholdsStyle": { "mode": "dashed" } },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0.995 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "sli:http_availability:ratio_rate5m", "legendFormat": "5m" },
        { "refId": "B", "expr": "sli:http_availability:ratio_rate1h", "legendFormat": "1h" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latency SLI trend (share under 500ms)",
      "description": "Share of requests under 500ms at 5m and 1h windows. The dashed threshold is the 95% SLO target.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "custom": { "thresholdsStyle": { "mode": "dashed" } },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "sli:http_latency_fast:ratio_rate5m", "legendFormat": "5m" },
        { "refId": "B", "expr": "sli:http_latency_fast:ratio_rate1h", "legendFormat": "1h" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Availability burn rate",
      "description": "Error-budget consumption speed. 1x = spending exactly the monthly budget. Dashed lines mark the alert thresholds: 14.4x (fast burn, pages when 5m AND 1h exceed it) and 6x (slow burn, warns when 30m AND 6h exceed it).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "min": 0,
          "custom": { "thresholdsStyle": { "mode": "dashed" } },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 6 },
              { "color": "red", "value": 14.4 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "slo:availability:burnrate5m", "legendFormat": "5m" },
        { "refId": "B", "expr": "slo:availability:burnrate30m", "legendFormat": "30m" },
        { "refId": "C", "expr": "slo:availability:burnrate1h", "legendFormat": "1h" },
        { "refId": "D", "expr": "slo:availability:burnrate6h", "legendFormat": "6h" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Latency burn rate",
      "description": "Same burn-rate mechanics against the 95%-under-500ms budget. Sustained values above the dashed lines fire SLOLatencyFastBurn / SLOLatencySlowBurn.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "min": 0,
          "custom": { "thresholdsStyle": { "mode": "dashed" } },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 6 },
              { "color": "red", "value": 14.4 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "slo:latency:burnrate5m", "legendFormat": "5m" },
        { "refId": "B", "expr": "slo:latency:burnrate30m", "legendFormat": "30m" },
        { "refId": "C", "expr": "slo:latency:burnrate1h", "legendFormat": "1h" },
        { "refId": "D", "expr": "slo:latency:burnrate6h", "legendFormat": "6h" }
      ]
    }
  ]
}
