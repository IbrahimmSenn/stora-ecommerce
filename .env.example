POSTGRES_USER=admin
POSTGRES_PASSWORD=secret
POSTGRES_DB=mystore
DATABASE_URL=postgres://admin:secret@localhost:5433/mystore?sslmode=disable

BCRYPT_COST=10

JWT_SECRET=replace-with-a-random-string-at-least-32-chars

# AES-256-GCM key for encrypting order PII at rest. 64 hex chars (32 bytes).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

PORT=8080
BASE_URL=http://localhost:8080

# OAuth (leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FB_CLIENT_ID=
FB_CLIENT_SECRET=

# reCAPTCHA v3
# Get keys at https://www.google.com/recaptcha/admin (choose v3, add localhost as domain)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
SKIP_CAPTCHA=true

# SMTP (for password reset emails + order confirmations).
# Defaults are for host-mode (`make run`); docker-compose overrides to the
# bundled Mailhog service. Mailhog UI at http://localhost:8025.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@iloveshopping.com

# Stripe sandbox (https://dashboard.stripe.com/test/apikeys)
# STRIPE_WEBHOOK_SECRET is shown when you start `stripe listen --forward-to ...`
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# RabbitMQ. Default is host-mode; docker-compose overrides to the bundled
# rabbitmq service. Management UI at http://localhost:15672 (guest/guest).
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Nominatim (OpenStreetMap) address verification. Free, no API key.
# Defaults work out of the box. Override only to point at a private Nominatim
# instance or to customize the User-Agent per OSM's usage policy
# (https://operations.osmfoundation.org/policies/nominatim/).
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# NOMINATIM_USER_AGENT=your-app/1.0 (you@example.com)
