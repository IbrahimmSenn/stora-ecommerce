DATABASE_URL=postgres://admin:secret@localhost:5432/mystore?sslmode=disable

BCRYPT_COST=10

JWT_SECRET=change-me-to-a-strong-secret-in-production

PORT=8080
BASE_URL=http://localhost:8080

# OAuth (leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FB_CLIENT_ID=
FB_CLIENT_SECRET=

# reCAPTCHA v3 (set SKIP_CAPTCHA=true for local development)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
SKIP_CAPTCHA=true

# SMTP (leave SMTP_HOST empty to skip sending emails in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
