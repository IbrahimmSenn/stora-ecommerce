POSTGRES_USER=admin
POSTGRES_PASSWORD=secret
POSTGRES_DB=mystore
DATABASE_URL=postgres://admin:secret@localhost:5433/mystore?sslmode=disable

BCRYPT_COST=10

JWT_SECRET=replace-with-a-random-string-at-least-32-chars

# AES-256-GCM key for encrypting order PII at rest. 64 hex chars (32 bytes).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

PORT=8080
BASE_URL=http://localhost:8080

# OAuth (leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FB_CLIENT_ID=
FB_CLIENT_SECRET=

# reCAPTCHA v3
# Get keys at https://www.google.com/recaptcha/admin (choose v3, add localhost as domain)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
SKIP_CAPTCHA=true

# SMTP (for password reset emails)
# Example using Mailtrap sandbox: https://mailtrap.io
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@iloveshopping.com
